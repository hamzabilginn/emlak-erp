# Bu dosyayı kopyalayıp proje kökünde ".env" olarak kaydedin (şifreyi girin).
#
# Yerel PostgreSQL için örnek (SSL genelde gerekmez):
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=emlak_erp
# DB_USER=postgres
# DB_PASSWORD=sizin_yerel_sifre
# DB_SSLMODE=disable
#
# --- Supabase (canlı / IPv4 pooler) ---

DB_HOST=db.yzrfgshzdnicenrqxdum.supabase.co
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=BURAYA_SUPABASE_VERITABANI_SIFRENIZ

# İsteğe bağlı (varsayılan require)
# DB_SSLMODE=require

# Tek satırda tercih ederseniz DB_* yerine sadece bunu kullanabilirsiniz:
# DATABASE_URL=postgresql://postgres:BURAYA_SIFRE@db.yzrfgshzdnicenrqxdum.supabase.co:6543/postgres?sslmode=require
