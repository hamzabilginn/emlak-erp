# Bu dosyayı kopyalayıp proje kökünde ".env" olarak kaydedin (şifreyi girin).
#
# Yerel PostgreSQL için örnek (SSL genelde gerekmez):
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=emlak_erp
# DB_USER=postgres
# DB_PASSWORD=sizin_yerel_sifre
# DB_SSLMODE=disable
#
# --- Supabase (canlı: Dashboard → Shared pooler, IPv4 uyumlu) ---
# Host db.*.supabase.co yerine pooler kullanın (örn. aws-1-ap-southeast-2.pooler.supabase.com).
# Kullanıcı: postgres.<project_ref> (pooler için)

DB_HOST=aws-1-ap-southeast-2.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.yzrfgshzdnicenrqxdum
DB_PASSWORD=jGsi/zC$95+fLQj

# İsteğe bağlı (varsayılan require)
# DB_SSLMODE=require

