RewriteEngine On

# Sondaki gereksiz / kaldır
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [L,R=301]

# Turkce URL -> router (php:apache imajinda mod_rewrite zaten acik)
RewriteRule ^portfoyler/?$ index.php?url=property/index [QSA,L]
RewriteRule ^portfoy-ekle/?$ index.php?url=property/create [QSA,L]
RewriteRule ^portfoy-kaydet/?$ index.php?url=property/store [QSA,L]
RewriteRule ^portfoy-duzenle/([0-9]+)/?$ index.php?url=property/edit/$1 [QSA,L]
RewriteRule ^portfoy-guncelle/([0-9]+)/?$ index.php?url=property/update/$1 [QSA,L]

RewriteRule ^musteriler/?$ index.php?url=customer/index [QSA,L]
RewriteRule ^musteri-sahsi/?$ index.php?url=customer/createIndividual [QSA,L]
RewriteRule ^musteri-kurumsal/?$ index.php?url=customer/createCorporate [QSA,L]

RewriteRule ^yer-gosterme/?$ index.php?url=viewing/index [QSA,L]
RewriteRule ^yer-gosterme-ekle/?$ index.php?url=viewing/create [QSA,L]

RewriteRule ^ortak-havuz/?$ index.php?url=network/index [QSA,L]
RewriteRule ^esnaf-kasasi/?$ index.php?url=cashbox/index [QSA,L]

RewriteRule ^kayit-ol/?$ index.php?url=register/index [QSA,L]
RewriteRule ^kayit-islemi/?$ index.php?url=register/store [QSA,L]

RewriteRule ^sitemap\.xml$ index.php?url=sitemap/index [QSA,L]


RewriteRule ^giris-yap/?$ index.php?url=auth/login [QSA,L]
RewriteRule ^cikis-yap/?$ index.php?url=auth/logout [QSA,L]

RewriteRule ^ana-pano/?$ index.php?url=dashboard/index [QSA,L]
RewriteRule ^vitrin/?$ index.php?url=showcase/index [QSA,L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [L]
